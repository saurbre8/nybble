{
    "name": "nybble",
    "displayName": "Nybble",
    "description": "A virtual pet that lives in your editor — feed it, play with it, build its home.",
    "version": "0.1.0",
    "engines": {
        "vscode": "^1.73.0"
    },
    "repository": {
        "type": "github",
        "url": "https://github.com/saurbre8/nybble"
    },
    "homepage": "https://saurbre8.github.io/nybble",
    "bugs": "https://github.com/saurbre8/nybble/issues",
    "publisher": "saurbre8",
    "categories": [
        "Other"
    ],
    "license": "MIT",
    "icon": "icon.png",
    "activationEvents": [
        "onCommand:nybble.start",
        "onCommand:nybble.feed",
        "onCommand:nybble.play",
        "onCommand:nybble.rename",
        "onCommand:nybble.status",
        "onWebviewPanel:nybblePanel",
        "onView:explorer",
        "onView:nybbleView",
        "onStartupFinished"
    ],
    "main": "./out/extension/extension.js",
    "browser": "./dist/web/extension-web.js",
    "contributes": {
        "views": {
            "explorer": [
                {
                    "type": "webview",
                    "id": "nybbleView",
                    "name": "Nybble",
                    "when": "nybble.position == 'explorer'",
                    "icon": "media/dog.svg"
                }
            ]
        },
        "menus": {
            "view/title": [
                {
                    "command": "nybble.feed",
                    "when": "view == nybbleView",
                    "group": "navigation@1"
                },
                {
                    "command": "nybble.play",
                    "when": "view == nybbleView",
                    "group": "navigation@2"
                },
                {
                    "command": "nybble.status",
                    "when": "view == nybbleView",
                    "group": "navigation@3"
                }
            ]
        },
        "commands": [
            {
                "command": "nybble.start",
                "title": "Open Nybble",
                "category": "Nybble",
                "icon": "media/dog.svg"
            },
            {
                "command": "nybble.feed",
                "title": "Feed Critter",
                "category": "Nybble",
                "icon": {
                    "dark": "media/icon/dark-add.svg",
                    "light": "media/icon/light-add.svg"
                }
            },
            {
                "command": "nybble.play",
                "title": "Play with Critter",
                "category": "Nybble",
                "icon": {
                    "dark": "media/icon/dark-circle-outline.svg",
                    "light": "media/icon/light-circle-outline.svg"
                }
            },
            {
                "command": "nybble.rename",
                "title": "Rename Critter",
                "category": "Nybble"
            },
            {
                "command": "nybble.status",
                "title": "Critter Status",
                "category": "Nybble",
                "icon": {
                    "dark": "media/icon/dark-throw-outline.svg",
                    "light": "media/icon/light-throw-outline.svg"
                }
            },
            {
                "command": "nybble.resetCritter",
                "title": "Reset Critter (Debug)",
                "category": "Nybble"
            },
            {
                "command": "nybble.changeTheme",
                "title": "Change Background Theme",
                "category": "Nybble"
            }
        ],
        "configuration": [
            {
                "title": "Nybble",
                "properties": {
                    "nybble.critterType": {
                        "type": "string",
                        "enum": [
                            "cat",
                            "dog",
                            "bunny",
                            "fox",
                            "frog"
                        ],
                        "default": "cat",
                        "description": "Your critter species (chosen at hatch, can be changed here to reset)",
                        "enumItemLabels": ["Cat", "Dog", "Bunny", "Fox", "Frog"]
                    },
                    "nybble.position": {
                        "type": "string",
                        "enum": [
                            "panel",
                            "explorer"
                        ],
                        "default": "explorer",
                        "description": "Where the Nybble panel appears",
                        "enumItemLabels": ["Panel", "Explorer Sidebar"]
                    },
                    "nybble.statDecayRate": {
                        "type": "string",
                        "enum": ["slow", "normal", "fast"],
                        "default": "normal",
                        "description": "How quickly your critter's stats decay over time",
                        "enumItemLabels": ["Slow", "Normal", "Fast"]
                    },
                    "nybble.showStatusBar": {
                        "type": "boolean",
                        "default": true,
                        "description": "Show critter mood icon in the status bar"
                    },
                    "nybble.theme": {
                        "type": "string",
                        "enum": [
                            "none",
                            "forest",
                            "castle",
                            "beach",
                            "winter",
                            "autumn"
                        ],
                        "default": "none",
                        "description": "Background theme for the critter habitat",
                        "enumItemLabels": ["None", "Forest", "Castle", "Beach", "Winter", "Autumn"]
                    }
                }
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile:panel": "webpack",
        "compile:extension": "tsc -p ./tsconfig.extension.json",
        "compile:test": "tsc -p ./tsconfig.test.json",
        "compile:web": "webpack",
        "compile": "npm run compile:panel && npm run compile:extension && npm run compile:test && npm run compile:web",
        "watch": "webpack && tsc -watch -p ./tsconfig.extension.json",
        "watch:web": "webpack --watch",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src --ext ts && prettier --check src",
        "lint:fix": "eslint src --ext ts --fix && prettier --write src",
        "test": "node ./out/test/runTest.js",
        "test:coverage": "COVERAGE=1 node ./out/test/runTest.js",
        "test:web": "vscode-test-web --browserType=chromium --extensionDevelopmentPath=. --extensionTestsPath=dist/web/test/suite/index.js",
        "test:gifs": "node ./out/test/gifs.js"
    },
    "devDependencies": {
        "@rbarilani/remove-source-map-url-webpack-plugin": "^1.1.0",
        "@types/chai": "^5.0.1",
        "@types/glob": "^7.1.3",
        "@types/jsdom": "^20.0.0",
        "@types/mocha": "^9.1.1",
        "@types/node": "^20.19.10",
        "@types/vscode": "^1.73.0",
        "@typescript-eslint/eslint-plugin": "^5.29.0",
        "@typescript-eslint/parser": "^5.29.0",
        "@vscode/l10n-dev": "^0.0.29",
        "@vscode/test-web": "^0.0.71",
        "chai": "^5.1.2",
        "eslint": "^8.18.0",
        "eslint-plugin-unused-imports": "^2.0.0",
        "glob": "^8.0.3",
        "gulp": "^5.0.0",
        "jsdom": "^20.0.0",
        "jsdom-global": "^3.0.2",
        "mocha": "^10.8.2",
        "nyc": "^15.1.0",
        "path-browserify": "^1.0.1",
        "prettier": "^2.8.8",
        "process": "^0.11.10",
        "ts-loader": "^9.3.0",
        "typescript": "^4.7.4",
        "typescript-eslint": "^0.0.1-alpha.0",
        "vscode-test": "^1.4.0",
        "webpack": "5.95.0",
        "webpack-cli": "^4.10.0"
    },
    "dependencies": {
        "@vscode/l10n": "^0.0.10"
    }
}
